ANTHROPIC_API_KEY=
INTERCOM_ACCESS_TOKEN=
ZENDESK_API_TOKEN=
ZENDESK_SUBDOMAIN=
SLACK_BOT_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
TWITTER_BEARER_TOKEN=
DATABASE_URL=postgresql://localhost:5432/pulseai
REDIS_URL=redis://localhost:6379/0

# Groq LLM (required for AI-powered analysis)
GROQ_API_KEY=your_groq_api_key_here

# Groq rate limiting
GROQ_MAX_RPM=25
GROQ_PRIMARY_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama3-8b-8192
GROQ_CACHE_TTL=300

# Real-time streaming
SSE_HEARTBEAT_INTERVAL=15
WS_PING_INTERVAL=30
MAX_SSE_CLIENTS=100

# Customer analysis
COHORT_WINDOW_MONTHS=3
RFM_SCORE_BUCKETS=5
ARRIVAL_FORECAST_DAYS=7
MAX_CUSTOMERS_PER_GROQ_BATCH=10
