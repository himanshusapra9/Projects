# App
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# Auth
JWT_SECRET=your-secret-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/listingpilot

# Redis
REDIS_URL=redis://localhost:6379

# Storage (MinIO locally)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=listingpilot-assets
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# AI
ANTHROPIC_API_KEY=your-anthropic-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OCR
AWS_TEXTRACT_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Channel APIs (use mock if empty)
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Feature Flags
ENABLE_MOCK_CHANNELS=true
ENABLE_WALMART_CONNECTOR=false
ENABLE_ETSY_CONNECTOR=false
ENABLE_VOICE_INGESTION=false

# Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
