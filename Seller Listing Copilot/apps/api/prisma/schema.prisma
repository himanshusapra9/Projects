generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE_TRIAL
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum Role {
  OWNER
  ADMIN
  OPERATOR
  REVIEWER
  VIEWER
}

enum Channel {
  AMAZON
  EBAY
  WALMART
  SHOPIFY
  ETSY
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  ERROR
  PENDING_AUTH
}

enum IngestionStatus {
  PENDING
  PROCESSING
  EXTRACTING
  BUILDING
  COMPLETE
  FAILED
}

enum AssetType {
  IMAGE
  PDF
  CSV
  XLSX
  URL
  SPREADSHEET
  UNKNOWN
}

enum ProductStatus {
  DRAFT
  REVIEW_READY
  APPROVED
  PUBLISHED
  ARCHIVED
}

enum ReviewStatus {
  NEEDS_REVIEW
  IN_REVIEW
  APPROVED
}

enum ExtractionMethod {
  OCR
  IMAGE_VISION
  LLM_INFERENCE
  STRUCTURED_PARSE
  URL_SCRAPE
  API_LOOKUP
  SELLER_CONFIRMED
  PRIOR_LISTING
}

enum PackageStatus {
  DRAFT
  VALIDATED
  APPROVED
  PUBLISHED
  FAILED
  SUPPRESSED
}

enum Severity {
  INFO
  WARNING
  ERROR
  BLOCKING
}

enum PublishStatus {
  PENDING
  SUCCESS
  FAILED
  ROLLED_BACK
}

enum MonitorStatus {
  ACTIVE
  PAUSED
  SUPPRESSED
  ERROR
}

enum RemediationType {
  SUPPRESSION_FIX
  MISSING_REQUIRED
  CATEGORY_MISMATCH
  CONTENT_DRIFT
  DISCOVERABILITY
  CONVERSION
}

enum RemediationStatus {
  OPEN
  APPLIED
  DISMISSED
}

model Organization {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  plan             Plan
  monthlyTokenUsage Int     @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users            User[]
  channelAccounts  ChannelAccount[]
  ingestionJobs    IngestionJob[]
  products         Product[]
  auditLogs        AuditLog[]
}

model User {
  id               String       @id @default(cuid())
  email            String       @unique
  passwordHash     String
  role             Role
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  refreshTokenHash String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([organizationId])
}

model ChannelAccount {
  id               String         @id @default(cuid())
  organizationId   String
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  channel          Channel
  name             String
  externalId       String?
  credentialsJson  Json
  status           AccountStatus
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([organizationId])
  @@index([organizationId, channel])
  @@index([organizationId, status])
}

model IngestionJob {
  id               String          @id @default(cuid())
  organizationId   String
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  status           IngestionStatus
  sourceLabel      String?
  errorMessage     String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  completedAt      DateTime?

  assets           SourceAsset[]
  products         Product[]

  @@index([organizationId])
  @@index([organizationId, status])
}

model SourceAsset {
  id                 String       @id @default(cuid())
  ingestionJobId     String
  ingestionJob       IngestionJob @relation(fields: [ingestionJobId], references: [id], onDelete: Cascade)
  type               AssetType
  originalFilename   String
  storageKey         String
  mimeType           String?
  sizeBytes          Int?
  checksumSha256     String?
  metadataJson       Json?
  createdAt          DateTime     @default(now())

  evidence           Evidence[]

  @@index([ingestionJobId])
}

model Product {
  id               String         @id @default(cuid())
  organizationId   String
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ingestionJobId   String?
  ingestionJob     IngestionJob?  @relation(fields: [ingestionJobId], references: [id], onDelete: SetNull)

  title            String?
  brand            String?
  modelNumber      String?
  upc              String?
  ean              String?
  asin             String?

  status           ProductStatus
  reviewStatus     ReviewStatus
  completeness     Float          @default(0)
  canonicalJson    Json?

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  variants         Variant[]
  attributes       Attribute[]
  evidenceRecords  Evidence[]
  listingPackages  ListingPackage[]
  monitors         Monitor[]
  publishEvents    PublishEvent[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, reviewStatus])
}

model Variant {
  id              String   @id @default(cuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku             String?
  title           String
  attributesJson  Json     @default("{}")
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([productId])
}

model Attribute {
  id               String           @id @default(cuid())
  productId        String
  product          Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  fieldName        String
  value            String
  normalizedValue  String?
  confidence       Float
  method           ExtractionMethod
  requiresReview   Boolean          @default(false)
  conflicted       Boolean          @default(false)
  approvedAt       DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  evidence         Evidence[]

  @@index([productId])
  @@index([productId, fieldName])
}

model Evidence {
  id              String       @id @default(cuid())
  productId       String
  product         Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  sourceAssetId   String?
  sourceAsset     SourceAsset? @relation(fields: [sourceAssetId], references: [id], onDelete: SetNull)
  attributeId     String?
  attribute       Attribute?   @relation(fields: [attributeId], references: [id], onDelete: SetNull)

  snippet         String?
  explanation     String
  confidence      Float
  regionJson      Json?
  createdAt       DateTime     @default(now())

  @@index([productId])
  @@index([attributeId])
  @@index([sourceAssetId])
}

model ListingPackage {
  id               String       @id @default(cuid())
  productId        String
  product          Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  channel          Channel
  status           PackageStatus
  title            String?
  bulletsJson      Json
  description      String?
  attributesJson   Json
  keywordsJson     Json
  imagesJson       Json
  qualityScore     Float?
  payloadJson      Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  validations      Validation[]
  publishEvents    PublishEvent[]

  @@unique([productId, channel])
  @@index([productId])
  @@index([productId, status])
}

model Validation {
  id                 String         @id @default(cuid())
  listingPackageId   String
  listingPackage     ListingPackage @relation(fields: [listingPackageId], references: [id], onDelete: Cascade)
  field              String
  rule               String
  severity           Severity
  message            String
  suggestedFix       String?
  createdAt          DateTime       @default(now())

  @@index([listingPackageId])
  @@index([listingPackageId, severity])
}

model PublishEvent {
  id                 String          @id @default(cuid())
  organizationId     String
  productId          String
  product            Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  listingPackageId   String?
  listingPackage     ListingPackage? @relation(fields: [listingPackageId], references: [id], onDelete: SetNull)
  channelAccountId   String?
  channel            Channel
  status             PublishStatus
  dryRun             Boolean         @default(false)
  channelListingId   String?
  errorMessage       String?
  rawResponseJson    Json?
  publishedAt        DateTime?
  createdAt          DateTime        @default(now())

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([productId])
}

model Monitor {
  id                 String       @id @default(cuid())
  organizationId     String
  productId          String
  product            Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  channel            Channel
  channelListingId   String
  status             MonitorStatus
  healthScore        Float?
  lastCheckedAt      DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  remediations       RemediationRecommendation[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([productId])
}

model RemediationRecommendation {
  id                 String            @id @default(cuid())
  monitorId          String
  monitor            Monitor           @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  type               RemediationType
  title              String
  description        String
  impactScore        Int
  suggestedFixJson   Json
  status             RemediationStatus
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([monitorId])
  @@index([monitorId, status])
}

model AuditLog {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId           String?
  action           String
  entityType       String
  entityId         String?
  detailsJson      Json?
  ipAddress        String?
  createdAt        DateTime @default(now())

  @@index([organizationId])
  @@index([organizationId, createdAt])
}
