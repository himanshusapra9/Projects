# Discovery Copilot — Environment Variables

# Server
NODE_ENV=development
PORT=3001

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=discovery_copilot
DB_USER=postgres
DB_PASSWORD=
DB_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# LLM
LLM_PROVIDER=openai
LLM_API_KEY=sk-...
LLM_DEFAULT_MODEL=gpt-4o-mini
LLM_EMBEDDING_MODEL=text-embedding-3-small
LLM_MAX_RETRIES=3
LLM_TIMEOUT_MS=30000

# Search
SEARCH_PROVIDER=elasticsearch
SEARCH_HOST=http://localhost:9200
SEARCH_INDEX_PREFIX=copilot

# Features
FEATURE_MEMORY=true
FEATURE_RETURN_RISK=true
FEATURE_REVIEW_INTEL=true
MAX_CLARIFICATION_QUESTIONS=3
MAX_RECOMMENDATIONS=5
SESSION_TTL_MINUTES=30

# Observability
LOG_LEVEL=info
TRACING_ENABLED=false
METRICS_ENABLED=false

# Frontend
ALLOWED_ORIGINS=http://localhost:3000
