# =============================================================================
# Return Prevention + Fit Confidence Engine — root environment template
# Copy to .env and fill in values. Never commit real secrets.
# =============================================================================

# --- Database & cache ---
# Primary Postgres connection (sessions, catalog pointers, audit logs)
DATABASE_URL=postgresql://user:password@localhost:5432/fitconfidence

# Redis for rate limiting, hot cache, job queues
REDIS_URL=redis://localhost:6379/0

# --- LLM / inference providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=

# --- Social / community ingestion (e.g. Reddit signals) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=fitconfidence-engine/1.0

# --- Auth & API security ---
# JWT signing for tenant sessions / BFF tokens
JWT_SECRET=change-me-min-32-chars-please

# Salt for hashing API keys (HMAC or key derivation)
API_KEY_SALT=change-me-api-key-salt

# Optional: encryption key for PII at rest (32-byte base64)
FIELD_ENCRYPTION_KEY=

# --- Public client (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_TENANT_ID=

# --- Observability ---
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=info

# --- Feature flags (optional) ---
FEATURE_COMMUNITY_SIGNALS=true
FEATURE_EXPERIMENTAL_RANKING=false

# --- Email / webhooks (optional) ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
WEBHOOK_SIGNING_SECRET=

# --- Object storage (optional, for exports) ---
S3_BUCKET=
S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
