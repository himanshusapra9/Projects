# Server
NODE_ENV=development
# Align with root .env.example NEXT_PUBLIC_API_URL (http://localhost:3001)
PORT=3001

# Comma-separated browser origins (defaults to http://localhost:3000 if unset)
CORS_ORIGIN=http://localhost:3000

# Postgres (catalog, memory, audit)
DATABASE_URL=postgresql://rpfit:rpfit@localhost:5432/rpfit
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=rpfit
POSTGRES_PASSWORD=rpfit
POSTGRES_DB=rpfit
POSTGRES_SSL=false

# Redis (sessions, cache, rate limits)
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Tenant / auth (dev keys — replace in production)
API_KEYS_JSON={"dev-server":"tenant_dev_1","dev-widget":"tenant_dev_1"}

# Rate limits (requests per minute per key)
RATE_LIMIT_RPM_SERVER=3000
RATE_LIMIT_RPM_WIDGET=600
